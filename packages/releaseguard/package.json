{
  "name": "releaseguard",
  "private": true,
  "version": "0.7.6",
  "description": "PR-aware merge impact coverage gate. Tells you whether the thing your PR actually changed was tested.",
  "license": "MIT",
  "keywords": [
    "ci",
    "pull-request",
    "merge",
    "code-review",
    "test-coverage",
    "ai-coding",
    "github-actions"
  ],
  "bin": {
    "releaseguard": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "tsx": "4.20.6",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
